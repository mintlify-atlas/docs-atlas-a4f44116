  "keyFeatures": [
    "Network egress filtering with audit and block modes",
    "Automated baseline creation for outbound network connections",
    "Real-time anomaly detection for CI/CD workflow runs",
    "File integrity monitoring during builds",
    "Process activity monitoring with step-level correlation",
    "Support for GitHub-hosted and self-hosted runners (Linux, Windows, macOS)",
    "Actions Runner Controller (ARC) support via eBPF",
    "Policy store for centralized configuration management",
    "GITHUB_TOKEN permissions minimization",
    "CI/CD-aware event correlation mapping activity to exact workflow steps"
  ],
